# Main iteration function
run_iteration <- function(seed, n_samples = 500) {
set.seed(seed)
tryCatch({
# Simulate data
sim_data <- simulate_dataDR(n_samples, n_features = 20, n_categories = 3,
feature_ranges = list(
categorical = list(min = 1, max = 5),
continuous = list(min = 0, max = 1),
seed
))
# Split data
