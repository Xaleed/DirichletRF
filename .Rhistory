library(DirichletRF)
library(DirichletRF)
# ── Data ──────────────────────────────────────────────────────────────────────
set.seed(42)
n <- 200; p <- 6
X <- matrix(rnorm(n * p), n, p)
colnames(X) <- paste0("X", 1:p)
# X1 and X2 are informative, X3-X6 are pure noise
alpha_mat <- cbind(
2 + 3 * (X[, 1] > 0),
3 + 3 * (X[, 2] > 0),
rep(4, n)
)
G <- matrix(rgamma(n * 3, shape = as.vector(t(alpha_mat))), n, 3, byrow = TRUE)
Y <- G / rowSums(G)
colnames(Y) <- c("A", "B", "C")
# ── 1. Default (fastest): no bootstrap, no OOB ────────────────────────────────
forest <- DirichletRF(X, Y, num.trees = 100, num.cores = 1)
print(forest)
importance(forest)
# ── 2. With OOB error ─────────────────────────────────────────────────────────
forest_oob <- DirichletRF(X, Y, num.trees = 100, num.cores = 1,
replace = TRUE, sample.fraction = 1.0,
oob.error = TRUE)
print(forest_oob)
forest_oob$oob$mse
head(forest_oob$oob$predictions)
# ── 3. Bootstrap without OOB ──────────────────────────────────────────────────
forest_boot <- DirichletRF(X, Y, num.trees = 100, num.cores = 1,
replace = TRUE, sample.fraction = 1.0,
oob.error = FALSE)
importance(forest_boot)
# ── 4. Subsampling at 63.2% (ranger-style no-replacement default) ─────────────
forest_sub <- DirichletRF(X, Y, num.trees = 100, num.cores = 1,
replace = FALSE, sample.fraction = 0.632,
oob.error = TRUE)
forest_sub$oob$mse
# ── 5. Prediction ─────────────────────────────────────────────────────────────
X_new <- matrix(rnorm(10 * p), 10, p)
colnames(X_new) <- paste0("X", 1:p)
preds <- predict(forest, newdata = X_new)
head(preds$mean_predictions)
# ── 6. Validation checks ──────────────────────────────────────────────────────
# Should error: OOB not available with replace=FALSE, sample.fraction=1
tryCatch(
DirichletRF(X, Y, replace = FALSE, sample.fraction = 1.0, oob.error = TRUE),
error = function(e) message("Expected error: ", e$message)
)
# Should error: sample.fraction out of range
tryCatch(
DirichletRF(X, Y, replace = FALSE, sample.fraction = 1.5),
error = function(e) message("Expected error: ", e$message)
)
# Should warn: sample.fraction very small
withCallingHandlers(
DirichletRF(X, Y, replace = FALSE, sample.fraction = 0.05, num.trees = 10),
warning = function(w) message("Expected warning: ", w$message)
)
