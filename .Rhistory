print(head(Y_test_original, 3))
cat("========================\n\n")
results$Dirichlet_RF <- list(
train = evaluate_performance(
Y_train_simplex, drf_results$predictions$train_simplex,
Y_train_original, drf_results$predictions$train_original,
row_sums_train, shared_train_pred_sums
),
test = evaluate_performance(
Y_test_simplex, drf_results$predictions$test_simplex,
Y_test_original, drf_results$predictions$test_original,
row_sums_test, shared_test_pred_sums
)
)
}
# 2. Dirichlet Regression
cat("\nFitting Dirichlet Regression...\n")
dr_results <- tryCatch({
fit_dirichlet_regression(X_train, Y_train_simplex,
X_test, Y_test_simplex,
shared_train_pred_sums, shared_test_pred_sums)
}, error = function(e) {
warning("Dirichlet Regression failed: ", e$message)
print(e)
NULL
})
if (!is.null(dr_results)) {
results$Dirichlet_Regression <- list(
train = evaluate_performance(
as.data.frame(Y_train_simplex), as.data.frame(dr_results$predictions$train_simplex),
as.data.frame(Y_train_original), as.data.frame(dr_results$predictions$train_original),
row_sums_train, shared_train_pred_sums
),
test = evaluate_performance(
as.data.frame(Y_test_simplex), as.data.frame(dr_results$predictions$test_simplex),
as.data.frame(Y_test_original), as.data.frame(dr_results$predictions$test_original),
row_sums_test, shared_test_pred_sums
)
)
}
# 3. CLR Random Forest
cat("\nFitting CLR RF...\n")
clr_results <- fit_clr_rf(X_train, Y_train_simplex,
X_test, Y_test_simplex,
shared_train_pred_sums, shared_test_pred_sums)
if (!is.null(clr_results)) {
cat("\n=== CLR RF DEBUG ===\n")
cat("Test predictions (first 3 samples):\n")
cat("  Simplex predictions:\n")
print(head(clr_results$predictions$test_simplex, 3))
cat("  Simplex row sums: ", head(rowSums(clr_results$predictions$test_simplex), 3), "\n")
cat("  Shared predicted sums: ", head(shared_test_pred_sums, 3), "\n")
cat("  Reconstructed original (simplex * sums):\n")
print(head(clr_results$predictions$test_original, 3))
cat("  Original row sums: ", head(rowSums(clr_results$predictions$test_original), 3), "\n")
cat("  True original values:\n")
print(head(Y_test_original, 3))
cat("========================\n\n")
results$CLR_RF <- list(
train = evaluate_performance(
as.data.frame(Y_train_simplex), as.data.frame(clr_results$predictions$train_simplex),
as.data.frame(Y_train_original), as.data.frame(clr_results$predictions$train_original),
row_sums_train, shared_train_pred_sums
),
test = evaluate_performance(
as.data.frame(Y_test_simplex), as.data.frame(clr_results$predictions$test_simplex),
as.data.frame(Y_test_original), as.data.frame(clr_results$predictions$test_original),
row_sums_test, shared_test_pred_sums
)
)
}
# 4. ILR Random Forest
cat("\nFitting ILR RF...\n")
ilr_results <- fit_ilr_rf(X_train, Y_train_simplex,
X_test, Y_test_simplex,
shared_train_pred_sums, shared_test_pred_sums)
if (!is.null(ilr_results)) {
results$ILR_RF <- list(
train = evaluate_performance(
as.data.frame(Y_train_simplex), as.data.frame(ilr_results$predictions$train_simplex),
as.data.frame(Y_train_original), as.data.frame(ilr_results$predictions$train_original),
row_sums_train, shared_train_pred_sums
),
test = evaluate_performance(
as.data.frame(Y_test_simplex), as.data.frame(ilr_results$predictions$test_simplex),
as.data.frame(Y_test_original), as.data.frame(ilr_results$predictions$test_original),
row_sums_test, shared_test_pred_sums
)
)
}
return(results)
}
# Main iteration function
run_iteration <- function(seed, n_samples = 500) {
set.seed(seed)
tryCatch({
# Simulate data
sim_data <- simulate_data1(n_samples, n_features = 15, n_categories = 3,
feature_ranges = list(
categorical = list(min = 1, max = 5),
continuous = list(min = 0, max = 1),
seed
))
# Split data
split_datasets <- split_data(sim_data$X, sim_data$Y_simplex,
sim_data$Y_original, sim_data$row_sums)
# Run models comparison
results <- compare_models(
split_datasets$X_train,
split_datasets$Y_train_simplex,
split_datasets$row_sums_train,
split_datasets$X_test,
split_datasets$Y_test_simplex,
split_datasets$row_sums_test
)
# Process results
metrics_list <- list()
for (model_name in names(results)) {
# Training metrics
if (!is.null(results[[model_name]]$train)) {
metrics_list[[length(metrics_list) + 1]] <- data.frame(
iteration = seed,
model = model_name,
dataset = "train",
aitchison_distance = results[[model_name]]$train$aitchison_distance,
MEC = results[[model_name]]$train$MEC,
RMSE_simplex = results[[model_name]]$train$mean_rmse_simplex,
RMSE_original = results[[model_name]]$train$mean_rmse_original,
MAE_original = results[[model_name]]$train$mean_mae_original,
RMSE_sums = results[[model_name]]$train$RMSE_sums,
MAE_sums = results[[model_name]]$train$MAE_sums
)
}
# Test metrics
if (!is.null(results[[model_name]]$test)) {
metrics_list[[length(metrics_list) + 1]] <- data.frame(
iteration = seed,
model = model_name,
dataset = "test",
aitchison_distance = results[[model_name]]$test$aitchison_distance,
MEC = results[[model_name]]$test$MEC,
RMSE_simplex = results[[model_name]]$test$mean_rmse_simplex,
RMSE_original = results[[model_name]]$test$mean_rmse_original,
MAE_original = results[[model_name]]$test$mean_mae_original,
RMSE_sums = results[[model_name]]$test$RMSE_sums,
MAE_sums = results[[model_name]]$test$MAE_sums
)
}
}
return(do.call(rbind, metrics_list))
}, error = function(e) {
warning(paste("Error in iteration", seed, ":", e$message))
return(data.frame(
iteration = numeric(),
model = character(),
dataset = character(),
aitchison_distance = numeric(),
MEC = numeric(),
RMSE_simplex = numeric(),
RMSE_original = numeric(),
MAE_original = numeric(),
RMSE_sums = numeric(),
MAE_sums = numeric()
))
})
}
# Example usage
cat("Running single iteration test...\n")
test_result <- run_iteration(seed = 132, n_samples = 500)
print(test_result)
