# Install plotly if needed: install.packages("plotly")
library(plotly)
# Create a grid of x and y values
x <- seq(-1, 2, length.out = 50)
y <- seq(-1, 2, length.out = 50)
# z = 1 - x - y (solved from x + y + z = 1)
z <- outer(x, y, function(x, y) 1 - x - y)
# Plot the surface
plot_ly(x = x, y = y, z = z, type = "surface",
colorscale = "Viridis",
opacity = 0.8) %>%
layout(
title = "Plane: x + y + z = 1",
scene = list(
xaxis = list(title = "x"),
yaxis = list(title = "y"),
zaxis = list(title = "z"),
camera = list(eye = list(x = 1.5, y = 1.5, z = 1.2))
)
)
# Create a grid of x and y values
x <- seq(0,1, length.out = 50)
y <- seq(0, 1, length.out = 50)
# z = 1 - x - y (solved from x + y + z = 1)
z <- outer(x, y, function(x, y) 1 - x - y)
# Plot the surface
plot_ly(x = x, y = y, z = z, type = "surface",
colorscale = "Viridis",
opacity = 0.8) %>%
layout(
title = "Plane: x + y + z = 1",
scene = list(
xaxis = list(title = "x"),
yaxis = list(title = "y"),
zaxis = list(title = "z"),
camera = list(eye = list(x = 1.5, y = 1.5, z = 1.2))
)
)
# Define the 3 vertices of the simplex triangle
vertices <- data.frame(
x = c(1, 0, 0),
y = c(0, 1, 0),
z = c(0, 0, 1)
)
# Draw the filled triangle using mesh3d
plot_ly() %>%
add_trace(
type = "mesh3d",
x = vertices$x,
y = vertices$y,
z = vertices$z,
i = 0, j = 1, k = 2,          # indices of the triangle face
facecolor = c("lightblue"),
opacity = 0.6,
name = "Simplex"
) %>%
# Add the triangle edges
add_trace(
type = "scatter3d", mode = "lines",
x = c(1, 0, 0, 1),
y = c(0, 1, 0, 0),
z = c(0, 0, 1, 0),
line = list(color = "steelblue", width = 4),
name = "Edges"
) %>%
# Mark the 3 vertices
add_trace(
type = "scatter3d", mode = "markers+text",
x = c(1, 0, 0),
y = c(0, 1, 0),
z = c(0, 0, 1),
text = c("(1,0,0)", "(0,1,0)", "(0,0,1)"),
textposition = "top center",
marker = list(size = 5, color = "red"),
name = "Vertices"
) %>%
layout(
title = "2-Simplex: x + y + z = 1, x,y,z ≥ 0",
scene = list(
xaxis = list(title = "x", range = c(0, 1)),
yaxis = list(title = "y", range = c(0, 1)),
zaxis = list(title = "z", range = c(0, 1)),
camera = list(eye = list(x = 1.4, y = 1.4, z = 1.1))
)
)
set.seed(42)
n <- 500
# Simulate independent counts for each subject
Math  <- round(runif(n, 10, 300))
Stats <- round(runif(n, 10, 300))
CS    <- round(runif(n, 10, 300))
data_original <- data.frame(Math, Stats, CS)
# Correlation in original space
cat("Correlation in original space:\n")
cat("corr(Math, Stats) =", round(cor(Math, Stats), 3), "\n\n")
# Normalize each row to sum to 100
row_totals <- Math + Stats + CS
Math_prop  <- 100 * Math  / row_totals
Stats_prop <- 100 * Stats / row_totals
CS_prop    <- 100 * CS    / row_totals
data_compositional <- data.frame(Math_prop, Stats_prop, CS_prop)
# Correlation in compositional (normalized) space
cat("Correlation in normalized (compositional) space:\n")
cat("corr(Math, Stats) =", round(cor(Math_prop, Stats_prop), 3), "\n\n")
# Show first 5 rows of both tables
cat("--- Original Data (first 5 rows) ---\n")
print(round(head(data_original, 5)))
cat("\n--- Compositional Data, normalized to 100 (first 5 rows) ---\n")
print(round(head(data_compositional, 5), 1))
