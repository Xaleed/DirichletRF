library(Rcpp)
# your Rcpp function
cppFunction('
void swap_numbers(int* a, int* b) {
int temp = *a;
*a = *b;
*b = temp;
}
')
cppFunction('
void swap_ptr(int* a, int* b) {
int temp = *a;   // pointer logic stays here
*a = *b;
*b = temp;
}
NumericVector swap_numbers(double a, double b) {
int x = (int)a;
int y = (int)b;
swap_ptr(&x, &y);    // use & INSIDE C++ — works fine!
return NumericVector::create(x, y);
}
')
library(Rcpp)
cppFunction('
void swap_ptr(int* a, int* b) {
int temp = *a;   // pointer logic stays here
*a = *b;
*b = temp;
}
NumericVector swap_numbers(double a, double b) {
int x = (int)a;
int y = (int)b;
swap_ptr(&x, &y);    // use & INSIDE C++ — works fine!
return NumericVector::create(x, y);
}
')
