# Run multiple iterations with different datasets (sequential)
run_multiple_iterations <- function(n_iterations = 10, n_samples = 500) {
cat(sprintf("Running %d iterations with %d samples each...\n", n_iterations, n_samples))
# Generate unique seeds for each iteration
seeds <- sample(1:10000, n_iterations)
# Initialize list to store results
all_results <- list()
# Run iterations sequentially
for (i in 1:n_iterations) {
cat(sprintf("\n--- Iteration %d/%d (seed=%d) ---\n", i, n_iterations, seeds[i]))
result <- run_iteration(seeds[i], n_samples)
if (nrow(result) > 0) {
all_results[[i]] <- result
cat(sprintf("✓ Iteration %d complete\n", i))
} else {
cat(sprintf("✗ Iteration %d failed\n", i))
}
}
# Combine all results
combined_results <- do.call(rbind, all_results)
cat("\n=== All iterations complete! ===\n")
cat(sprintf("Total successful iterations: %d/%d\n", length(all_results), n_iterations))
return(combined_results)
}
# Summarize results across iterations
summarize_multiple_iterations <- function(results_df) {
library(dplyr)
cat("\n=== SUMMARY ACROSS ALL ITERATIONS ===\n\n")
# Check if results are empty
if (nrow(results_df) == 0) {
cat("ERROR: No results to summarize. All iterations failed.\n")
cat("Check the error messages above for debugging.\n")
return(NULL)
}
cat(sprintf("Total rows in results: %d\n", nrow(results_df)))
cat(sprintf("Models found: %s\n", paste(unique(results_df$model), collapse = ", ")))
cat(sprintf("Datasets: %s\n\n", paste(unique(results_df$dataset), collapse = ", ")))
# Calculate mean and sd for each model and dataset
summary_stats <- results_df %>%
group_by(model, dataset) %>%
summarise(
mean_aitchison = mean(aitchison_distance, na.rm = TRUE),
sd_aitchison = sd(aitchison_distance, na.rm = TRUE),
mean_MEC = mean(MEC, na.rm = TRUE),
sd_MEC = sd(MEC, na.rm = TRUE),
mean_RMSE_simplex = mean(RMSE_simplex, na.rm = TRUE),
sd_RMSE_simplex = sd(RMSE_simplex, na.rm = TRUE),
mean_RMSE_original = mean(RMSE_original, na.rm = TRUE),
sd_RMSE_original = sd(RMSE_original, na.rm = TRUE),
mean_MAE_original = mean(MAE_original, na.rm = TRUE),
sd_MAE_original = sd(MAE_original, na.rm = TRUE),
n_iterations = n(),
.groups = 'drop'
)
print(summary_stats)
# Create visualization only if we have data
if (nrow(summary_stats) > 0) {
library(ggplot2)
library(tidyr)
# Reshape for plotting
plot_data <- summary_stats %>%
select(model, dataset, mean_aitchison, mean_MEC, mean_RMSE_original) %>%
pivot_longer(cols = starts_with("mean_"), names_to = "metric", values_to = "value") %>%
mutate(metric = gsub("mean_", "", metric))
p <- ggplot(plot_data, aes(x = model, y = value, fill = dataset)) +
geom_bar(stat = "identity", position = "dodge") +
facet_wrap(~metric, scales = "free_y") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
labs(title = "Model Performance Comparison Across Multiple Iterations",
x = "Model", y = "Mean Value", fill = "Dataset")
print(p)
}
return(summary_stats)
}
